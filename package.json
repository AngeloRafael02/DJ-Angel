{
  "name": "dj-angel",
  "version": "1.0.0",
  "description": "A Discord DJ Bot that uses a public google drive folder as their music library ",
  "keywords": [
    "DiscordJS",
    "googleapis"
  ],
  "homepage": "https://github.com/AngeloRafael02/DJ-Angel#readme",
  "bugs": {
    "url": "https://github.com/AngeloRafael02/DJ-Angel/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AngeloRafael02/DJ-Angel.git"
  },
  "license": "ISC",
  "author": "Angelo Rafael F. Recio",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "tsx src/index.ts",
    "prepm2:start": "node -e \"require('fs').mkdirSync('logs',{recursive:true})\"",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop dj-angel",
    "pm2:restart": "pm2 restart dj-angel",
    "pm2:delete": "pm2 delete dj-angel",
    "pm2:logs": "pm2 logs dj-angel",
    "pm2:logrotate:install": "pm2 install pm2-logrotate",
    "pm2:logrotate:configure": "pm2 set pm2-logrotate:max_size 10M && pm2 set pm2-logrotate:retain 7 && pm2 set pm2-logrotate:compress true"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "lavalink-client": "^2.9.9",
    "pm2": "^6.0.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
